{
  "name": "team-data-core",
  "version": "0.1.0",
  "description": "Shared GitHub/Linear data fetching and SQLite storage for engineering tools",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "npm test && tsup",
    "prepare": "npm test && tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run tests/integration/"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "octokit": "^5.0.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.8.0",
    "vitest": "^4.1.0"
  },
  "files": ["dist"],
  "license": "MIT"
}
